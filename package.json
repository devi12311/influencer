{
  "name": "ai-influencer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "prisma generate && next build && tsup src/worker.ts --format cjs --target node22 --out-dir dist --clean",
    "build:worker": "tsup src/worker.ts --format cjs --target node22 --out-dir dist --clean",
    "start": "next start",
    "start:worker": "node dist/worker.js",
    "typecheck": "node -e \"require('node:fs').rmSync('.next/types',{recursive:true,force:true})\" && tsc --noEmit",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "lint": "eslint src tests next.config.ts playwright.config.ts vitest.config.ts eslint.config.mjs",
    "format": "prettier --write .",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.900.0",
    "@aws-sdk/s3-request-presigner": "^3.900.0",
    "@google/genai": "^1.29.0",
    "@hookform/resolvers": "^5.2.2",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-query": "^5.90.5",
    "bullmq": "^5.61.2",
    "clsx": "^2.1.1",
    "ioredis": "^5.8.2",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.25",
    "pino": "^9.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.65.0",
    "react-photo-album": "^3.1.0",
    "sharp": "^0.34.4",
    "tailwind-merge": "^3.3.1",
    "yet-another-react-lightbox": "^3.25.0",
    "zod": "^4.1.12",
    "react-dropzone": "^14.3.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.3",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "prisma": "^6.6.0",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
